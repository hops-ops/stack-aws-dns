# code: language=yaml
#
# Output XR status
#

{{- $xr := getCompositeResource . }}
{{- $s := $state.status }}
---
apiVersion: {{ $xr.apiVersion }}
kind: {{ $xr.kind }}
status:
  ready: {{ $s.ready }}
  {{- if gt (len $s.hostedZones) 0 }}
  hostedZones:
    {{- range $hz := $s.hostedZones }}
    - domain: {{ $hz.domain }}
      zoneId: {{ $hz.zoneId | default "" | quote }}
    {{- end }}
  {{- end }}
